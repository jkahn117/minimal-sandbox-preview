---
import EditorPane from "./EditorPane.astro";

interface Props {
  sandboxId: string;
  host: string;
}

const { sandboxId, host } = Astro.props;

/**
 * The file inside the sandbox that the editor will load and save.
 * This is the Slidev slides markdown file.
 */
const editableFile = "/workspace/app/slides.md";
---

<!--
  Sandbox lifecycle + split-pane preview.

  Three states:
    loading  — spinner + progress text while container initializes
    ready    — code editor (left) + live preview iframe (right)
    error    — error message + retry button

  The EditorPane component handles file read/write independently.
  When the user saves, EditorPane dispatches a "sandbox:preview-reload"
  event and this component refreshes the iframe with a cache-busting
  query parameter.
-->

<div
  class="sandbox-container"
  x-data="sandbox"
  data-sandbox-id={sandboxId}
  data-host={host}
  data-editable-file={editableFile}
>
  <!-- Loading state -->
  <div class="loading-state" x-show="state === 'loading'">
    <div class="spinner"></div>
    <div class="status-text" x-text="statusText"></div>
    <div class="step-indicator" x-text="stepKey"></div>
  </div>

  <!-- Ready state: editor + preview -->
  <div class="ready-state" x-show="state === 'ready'" x-cloak>
    <div class="preview-url-bar">
      <span class="preview-url-label">Preview URL:</span>
      <a
        class="preview-url-link"
        :href="previewUrl"
        x-text="previewUrl"
        target="_blank"
        rel="noopener noreferrer"
      ></a>
    </div>
    <div class="split-pane">
      <div class="editor-pane" x-ref="editorPane">
        <EditorPane />
      </div>
      <div class="preview-pane" x-ref="previewPane">
        <iframe
          title="Sandbox Preview"
          loading="lazy"
          :src="previewUrl"
          x-ref="previewIframe"
          allow="screen-wake-lock"
        ></iframe>
      </div>
    </div>
  </div>

  <!-- Error state -->
  <div class="error-state" x-show="state === 'error'" x-cloak>
    <div class="error-message" x-text="errorMessage"></div>
    <button class="retry-btn" @click="location.reload()">Retry</button>
  </div>
</div>

<script>
  /**
   * Thin Alpine.js binding layer. All WS/polling logic lives in
   * SandboxPreview (src/lib/sandbox-preview.ts). This script wires
   * the library's events to Alpine's reactive state, and triggers
   * the EditorPane to load the file once the sandbox is ready.
   */
  import Alpine from "alpinejs";
  import { actions } from "astro:actions";
  import { SandboxPreview, type ActionResult } from "../lib/sandbox-preview";

  const STEP_DESCRIPTIONS: Record<string, string> = {
    starting: "Starting sandbox...",
    writing_files: "Scaffolding Slidev app...",
    starting_server: "Starting Slidev dev server...",
    waiting_for_ready: "Waiting for server to be ready...",
    exposing_port: "Configuring preview URL...",
  };

  const containerEl = document.querySelector<HTMLElement>(".sandbox-container");
  const sandboxId = containerEl?.dataset.sandboxId ?? "";
  const host = containerEl?.dataset.host ?? window.location.host;
  const editableFile = containerEl?.dataset.editableFile ?? "";

  /** True when running under Vite's dev server (localhost / 127.0.0.1). */
  const isLocalDev =
    window.location.hostname === "localhost" ||
    window.location.hostname === "127.0.0.1";

  /** Adapt Astro Actions' result shape to what SandboxPreview expects. */
  const callAction = async (): Promise<ActionResult> => {
    const result = await actions.startSandbox({ sandboxId, host });
    if (result.error) {
      return { error: { message: result.error.message } };
    }
    const data = result.data as ActionResult["data"];
    return { data };
  };

  Alpine.data("sandbox", () => ({
    state: "loading" as "loading" | "ready" | "error",
    statusText: "Initializing...",
    stepKey: "",
    previewUrl: "",
    errorMessage: "",

    _preview: null as SandboxPreview | null,
    _watchSource: null as EventSource | null,
    _refreshTimer: null as ReturnType<typeof setTimeout> | null,

    init() {
      console.log("[sandbox] Alpine init, sandboxId=%s host=%s isLocalDev=%s", sandboxId, host, isLocalDev);
      const preview = new SandboxPreview({
        start: callAction,
        poll: callAction,
        // In local dev the Vite dev server can't proxy WS upgrades to
        // worker-entry.ts, so the WS path never succeeds. Start polling
        // immediately with a short interval. In production, give the
        // WS path a brief 3s head start before falling back to polling.
        pollFallbackDelayMs: isLocalDev ? 0 : 3_000,
        pollIntervalMs: isLocalDev ? 2_000 : 3_000,
      });

      preview.on("progress", ({ step }) => {
        console.log("[sandbox] progress: %s", step);
        const baseStep = step.includes(":") ? step.split(":")[0].trim() : step;
        this.statusText = STEP_DESCRIPTIONS[baseStep] ?? step;
        this.stepKey = baseStep;
      });

      preview.on("ready", ({ previewUrl }) => {
        console.log("[sandbox] state -> ready, previewUrl:", previewUrl);
        this.state = "ready";
        this.previewUrl = previewUrl;

        // Tell the EditorPane to load the file.
        // $nextTick ensures the editor DOM is visible before we call load().
        this.$nextTick(() => {
          const editorEl = (this.$refs as Record<string, HTMLElement>).editorPane;
          const editorData: { load?: (id: string, filePath: string) => void } =
            Alpine.$data(
              editorEl?.querySelector("[x-data='editor']") as HTMLElement,
            ) as unknown as { load?: (id: string, filePath: string) => void };
          if (editorData?.load) {
            editorData.load(sandboxId, editableFile);
          }
        });

        // For editor saves, Vite HMR handles live updates automatically
        // via the WebSocket routed through proxyToSandbox().
        //
        // The SSE file watcher is a fallback for changes made outside
        // the editor (e.g. from a terminal session).
        this.startFileWatch();
      });

      preview.on("error", ({ message }) => {
        console.error("[sandbox] state -> error:", message);
        this.state = "error";
        this.errorMessage = message;
      });

      this._preview = preview;
      preview.init();
    },

    /** Connect to the SSE file-watch endpoint for the editable file. */
    startFileWatch() {
      // watch() requires a directory, so we split the editable file path
      // into dir + filename and filter server-side for just that file.
      const dir = editableFile.substring(0, editableFile.lastIndexOf("/"));
      const file = editableFile.substring(editableFile.lastIndexOf("/") + 1);
      const watchUrl = `/api/watch?sandboxId=${encodeURIComponent(sandboxId)}&dir=${encodeURIComponent(dir)}&file=${encodeURIComponent(file)}`;
      console.log("[sandbox:sse] connecting to", watchUrl);
      const source = new EventSource(watchUrl);

      source.onopen = () => {
        console.log("[sandbox:sse] connected");
      };

      source.onmessage = (event) => {
        try {
          const data = JSON.parse(event.data);
          console.log("[sandbox:sse] message:", data.type, data.eventType ?? "");
          // Only refresh on actual file modifications
          if (data.type === "event" && data.eventType === "modify") {
            console.log("[sandbox:sse] file modified, triggering refreshPreview");
            this.refreshPreview();
          }
        } catch {
          // Ignore parse errors
        }
      };

      source.onerror = () => {
        console.warn("[sandbox:sse] connection error, will retry...");
      };

      this._watchSource = source;
    },

    /**
     * Fallback refresh for changes made outside the editor (e.g. terminal).
     * Vite HMR handles editor saves automatically.
     *
     * Because the preview iframe is cross-origin (different subdomain),
     * we can't call contentWindow.location.reload(). Instead, we create
     * a hidden second iframe that loads the new content behind the scenes.
     * Once it fires "load", we swap it in and remove the old one.
     *
     * Debounced to 200ms to coalesce rapid inotify events from SSE.
     */
    refreshPreview() {
      console.log("[sandbox:refresh] debounced refresh requested");
      if (this._refreshTimer) clearTimeout(this._refreshTimer);
      this._refreshTimer = setTimeout(() => {
        if (!this.previewUrl) return;
        console.log("[sandbox:refresh] creating new iframe for:", this.previewUrl);
        const pane = (this.$refs as Record<string, HTMLElement>).previewPane;
        const oldIframe = (this.$refs as Record<string, HTMLIFrameElement>).previewIframe;
        if (!pane || !oldIframe) return;

        // Create a hidden iframe that loads the updated content
        const newIframe = document.createElement("iframe");
        newIframe.title = "Sandbox Preview";
        newIframe.allow = "screen-wake-lock";
        newIframe.src = this.previewUrl;
        newIframe.style.cssText =
          "position:absolute;top:0;left:0;width:100%;height:100%;border:none;opacity:0;";

        newIframe.addEventListener("load", () => {
          console.log("[sandbox:refresh] new iframe loaded, swapping in");
          newIframe.style.opacity = "1";
          newIframe.style.position = "";
          newIframe.setAttribute("x-ref", "previewIframe");
          oldIframe.remove();
        }, { once: true });

        // Position the pane as relative so the hidden iframe overlays correctly
        pane.style.position = "relative";
        pane.appendChild(newIframe);
      }, 200);
    },

    destroy() {
      this._preview?.destroy();
      this._watchSource?.close();
      if (this._refreshTimer) clearTimeout(this._refreshTimer);
    },
  }));

  Alpine.start();
</script>

<style>
  [x-cloak] {
    display: none !important;
  }

  .sandbox-container {
    max-width: 1400px;
    margin: 0 auto;
  }

  /* Loading */
  .loading-state {
    background: white;
    border: 1px solid #ddd;
    border-radius: 4px;
    padding: 40px;
    text-align: center;
    height: 400px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }

  .spinner {
    width: 40px;
    height: 40px;
    border: 4px solid #e3f2fd;
    border-top: 4px solid #2196f3;
    border-radius: 50%;
    animation: spin 1s linear infinite;
    margin-bottom: 20px;
  }

  @keyframes spin {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
  }

  .step-indicator {
    color: #666;
    font-size: 14px;
    margin-top: 10px;
    font-family: monospace;
  }

  /* Split pane */
  .preview-url-bar {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 12px;
    padding: 10px 12px;
    border: 1px solid #ddd;
    border-radius: 4px;
    background: #fff;
    font-family: monospace;
    font-size: 13px;
  }

  .preview-url-label {
    color: #333;
    flex-shrink: 0;
  }

  .preview-url-link {
    color: #1565c0;
    text-decoration: none;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .preview-url-link:hover {
    text-decoration: underline;
  }

  .split-pane {
    display: flex;
    border: 1px solid #333;
    border-radius: 4px;
    overflow: hidden;
    height: 650px;
  }

  .editor-pane {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
  }

  .preview-pane {
    flex: 1;
    min-width: 0;
    border-left: 2px solid #333;
    position: relative;
  }

  .preview-pane iframe {
    width: 100%;
    height: 100%;
    border: none;
    background: white;
  }

  /* Error */
  .error-state {
    text-align: center;
    padding: 40px;
  }

  .error-message {
    color: #d32f2f;
    margin-bottom: 20px;
  }

  .retry-btn {
    padding: 10px 20px;
    font-size: 16px;
    cursor: pointer;
    background: #2196f3;
    color: white;
    border: none;
    border-radius: 4px;
  }

  .retry-btn:hover {
    background: #1976d2;
  }
</style>
